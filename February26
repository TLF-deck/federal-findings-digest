<script>
  function filterProgram(filter) {
    document.querySelectorAll('.f-pill').forEach(p => p.classList.toggle('active', p.dataset.filter === filter));
    let delay = 0;
    document.querySelectorAll('.cal-entry').forEach(entry => {
      const show = filter === 'all' || entry.dataset.program === filter;
      entry.classList.toggle('hidden', !show);
      if (show) {
        entry.style.animationDelay = (delay * 0.06) + 's';
        entry.style.animation = 'none';
        void entry.offsetHeight;
        entry.style.animation = '';
        delay++;
      }
    });
    document.querySelectorAll('.cal-section-label').forEach(label => {
      const section = label.dataset.section;
      label.style.display = (filter === 'all' || section === filter) ? '' : 'none';
    });
  }
</script>
